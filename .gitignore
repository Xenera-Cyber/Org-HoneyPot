# Ignore everything by default
*

# Allow directories to be traversed
!*/

# Explicitly ignore environment, cache, and editor directories
.venv/
venv/
env/
__pycache__/
.cache/
.vscode/
logs/

# Allow Python files
!*.py
!**/*.py

# Allow Markdown documentation
!*.md
!**/*.md

# Allow .gitignore files
!.gitignore
!**/.gitignore

# Allow .env files
!.env
!**/.env


